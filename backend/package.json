{
  "name": "pmg-backend",
  "version": "1.0.0",
  "description": "Pocket Monster Go - Backend Microservices",
  "private": true,
  "workspaces": [
    "shared",
    "services/*",
    "gateway"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev -w shared\" \"npm run dev -w services/user-service\" \"npm run dev -w services/location-service\" \"npm run dev -w services/pokemon-service\" \"npm run dev -w services/catch-service\" \"npm run dev -w services/gym-service\"",
    "test": "npm run test --workspaces --if-present",
    "test:unit": "node tests/unit/catch.test.js && node tests/unit/auth.test.js && node tests/unit/spawn.test.js && node tests/unit/logger-metrics.test.js && node tests/unit/payment.test.js",
    "test:integration": "jest --config tests/integration/jest.config.json",
    "test:e2e": "jest --config tests/integration/jest.config.json tests/e2e",
    "test:all": "npm run test:unit && npm run test:integration",
    "test:coverage": "nyc npm run test:unit",
    "test:performance": "cd tests/performance && ./run-performance-tests.sh --scenario comprehensive --report",
    "test:performance:auth": "cd tests/performance && ./run-performance-tests.sh --scenario auth --report",
    "test:performance:catch": "cd tests/performance && ./run-performance-tests.sh --scenario catch --report",
    "test:performance:gym": "cd tests/performance && ./run-performance-tests.sh --scenario gym --report",
    "test:performance:payment": "cd tests/performance && ./run-performance-tests.sh --scenario payment --report",
    "lint": "eslint . --ext .js,.ts",
    "test:contract": "node tests/contract/run-contract-tests.js",
    "contract:check": "node tests/contract/check-compatibility.js",
    "migrate:up": "node ../database/migrate.js up",
    "migrate:down": "node ../database/migrate.js down",
    "migrate:status": "node ../database/migrate.js status",
    "migrate:create": "node ../database/migrate.js create",
    "migrate:verify": "node ../database/migrate.js verify"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^12.0.1",
    "@testcontainers/redis": "^12.0.1",
    "chai": "^4.5.0",
    "concurrently": "^8.2.0",
    "eslint": "^8.55.0",
    "jest": "^30.4.2",
    "nyc": "^18.0.0",
    "proxyquire": "^2.1.3",
    "sinon": "^22.0.0",
    "supertest": "^7.2.2",
    "testcontainers": "^12.0.1"
  },
  "dependencies": {
    "@opentelemetry/exporter-jaeger": "^2.7.1",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-node": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "axios": "^1.17.0",
    "express-validator": "^7.3.2",
    "kafkajs": "^2.2.4",
    "node-cron": "^4.5.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "rate-limit-redis": "^6.0.0",
    "redis": "^6.0.0",
    "speakeasy": "^2.0.0",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  }
}
