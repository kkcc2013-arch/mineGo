{
  "name": "minego",
  "version": "1.0.0",
  "description": "基于真实 GPS 的 AR 精灵捕捉手游",
  "scripts": {
    "setup": "node scripts/dev-setup.js",
    "doctor": "node scripts/dev-doctor.js",
    "reset": "node scripts/dev-reset.js",
    "seed": "node database/seeds/index.js",
    "seed:clean": "node database/seeds/index.js --clean",
    "seed:refresh": "node database/seeds/index.js --refresh",
    "dev": "docker compose up -d && npm run dev:backend",
    "dev:backend": "cd backend && npm run dev",
    "dev:gateway": "cd backend/gateway && npm run dev",
    "migrate:up": "node database/migrate.js up",
    "migrate:down": "node database/migrate.js down",
    "test": "cd backend && npm test",
    "lint": "cd backend && npm run lint",
    "clean": "rm -rf node_modules backend/node_modules frontend/node_modules coverage .nyc_output",
    "reinstall": "npm run clean && npm install && cd backend && npm install"
  },
  "devDependencies": {
    "chai": "^4.5.0",
    "sinon": "^22.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "game",
    "ar",
    "gps",
    "pokemon",
    "microservices"
  ],
  "license": "MIT"
}
